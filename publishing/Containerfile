FROM debian:bookworm-slim

# Install pandoc + XeLaTeX + required font packages + python (for canonical
# patterns.yaml → drafts/22-pattern-quick-reference.md regeneration in build.sh)
RUN apt-get update && apt-get install -y --no-install-recommends \
    pandoc \
    texlive-xetex \
    texlive-fonts-recommended \
    texlive-fonts-extra \
    texlive-latex-extra \
    texlive-plain-generic \
    texlive-bibtex-extra \
    latexmk \
    biber \
    fonts-texgyre \
    fonts-inconsolata \
    lmodern \
    poppler-utils \
    curl \
    ca-certificates \
    # python3 + python3-yaml: only needed for generate-quick-reference.py (pattern books). \
    # Remove these two lines if your book has no patterns.yaml pattern catalog. \
    python3 \
    python3-yaml \
    && rm -rf /var/lib/apt/lists/*

# eisvogel template — mounted at runtime or downloaded by entrypoint
# See run-container.sh for how to supply it

WORKDIR /data
